# ==============================================================================
# Furniture Catalog — Backend environment
# Copy to .env (dev) or export these in your runtime environment (prod).
# Spring reads each value with Spring Boot's relaxed binding.
# ==============================================================================

# ---- Profile -----------------------------------------------------------------
# dev (default) | prod | test
SPRING_PROFILES_ACTIVE=dev

# ---- Server ------------------------------------------------------------------
SERVER_PORT=8080

# ---- Database ----------------------------------------------------------------
# Required in prod. In dev these defaults assume the local docker-compose Postgres.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/furniture_catalog
SPRING_DATASOURCE_USERNAME=furniture
SPRING_DATASOURCE_PASSWORD=furniture
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# ---- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the public + admin SPAs.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- Storage -----------------------------------------------------------------
# local now, s3 later — same StorageService interface.
APP_STORAGE_PROVIDER=local
# Absolute or relative path on the host filesystem.
APP_STORAGE_LOCAL_ROOT=./var/uploads
# Public URL prefix the API uses when serialising image URLs.
APP_STORAGE_PUBLIC_BASE_URL=http://localhost:8080/media

# ---- Security: JWT -----------------------------------------------------------
# MUST be at least 32 ASCII characters (256 bits) for HS256.
APP_JWT_SECRET=replace-with-a-256-bit-secret-min-32-chars

# ---- Bootstrap admin (one-shot) ----------------------------------------------
# When true AND no active admin exists, the SUPER_ADMIN below is seeded on
# startup. Leave disabled in prod unless you're provisioning a fresh env.
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_EMAIL=admin@ebellaaz.local
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_NAME=Site Administrator

# ---- OpenAPI / Swagger -------------------------------------------------------
# false in prod by default; flip true to expose /swagger-ui.html.
SPRINGDOC_ENABLED=true

# ---- Logging -----------------------------------------------------------------
# Add custom overrides via the standard logging.level.* keys, e.g.
# LOGGING_LEVEL_COM_COMPANY_FURNITURECATALOG=DEBUG
