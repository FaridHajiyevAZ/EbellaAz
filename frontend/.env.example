# Base URL of the Spring Boot backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Public base URL the admin panel uses to link to the live site
VITE_PUBLIC_SITE_URL=http://localhost:5173

# If set, Vite dev server proxies /api and /media to this origin (avoids CORS in dev).
# Leave blank to call the backend directly via VITE_API_BASE_URL.
VITE_DEV_PROXY_TARGET=http://localhost:8080
