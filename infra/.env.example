# =============================================================================
# Compose-level env vars. Copy to infra/.env and edit.
# Backend-internal vars (DB url, etc.) are wired automatically by compose.
# =============================================================================

# ---- Public origin -----------------------------------------------------------
# Used by:
#   - APP_CORS_ALLOWED_ORIGINS (browser origin allowed by the backend)
#   - APP_STORAGE_PUBLIC_BASE_URL (image URLs returned by the API)
#   - VITE_PUBLIC_SITE_URL (built into the frontend bundle)
# Use https://your-domain in production.
PUBLIC_SITE_URL=http://localhost
PUBLIC_PORT=80

# ---- Postgres ---------------------------------------------------------------
POSTGRES_DB=furniture_catalog
POSTGRES_USER=furniture
POSTGRES_PASSWORD=replace-with-a-strong-password

# ---- Backend secrets --------------------------------------------------------
# REQUIRED. ≥ 32 ASCII chars (256 bits) for the HS256 JWT secret.
APP_JWT_SECRET=replace-with-a-256-bit-secret-min-32-chars

# ---- One-shot admin bootstrap (first deploy only) ---------------------------
# Set true + provide a password the first time you bring the stack up.
# Flip back to false after the first successful login + password rotation.
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_EMAIL=admin@ebellaaz.local
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_NAME=Site Administrator

# ---- OpenAPI / Swagger ------------------------------------------------------
# Off by default in prod. Flip true if you need /swagger-ui.html exposed.
SPRINGDOC_ENABLED=false
